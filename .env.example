# SmallCode Environment Variables
# Copy this to .env and fill in your values

# ─── Model Endpoint ──────────────────────────────────────────────────────────
# LM Studio (default)
SMALLCODE_BASE_URL=http://localhost:1234/v1
SMALLCODE_MODEL=your-model-name

# Ollama (alternative)
# OLLAMA_HOST=http://localhost:11434

# ─── Escalation (optional) ───────────────────────────────────────────────────
# Set ONE of these to enable auto-escalation to a stronger model on hard fail
# Priority: Anthropic > OpenAI > DeepSeek

# ANTHROPIC_API_KEY=sk-ant-...
# OPENAI_API_KEY=sk-...
# DEEPSEEK_API_KEY=sk-...

# ─── Escalation Model Override (optional) ────────────────────────────────────
# Default: claude-sonnet-4-20250514 (Anthropic), gpt-4o-mini (OpenAI)
# SMALLCODE_ESCALATION_MODEL=claude-sonnet-4-20250514
